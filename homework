# Basic Power Calculator
print("=" * 40)
print("     SIMPLE POWER CALCULATOR")
print("=" * 40)

# Get inputs from user
base = float(input("Enter the base number: "))
exponent = int(input("Enter the exponent (power): "))

# Calculate power
result = base ** exponent

# Display result
print(f"\n{base} raised to the power {exponent} = {result}")
print(f"Calculation: {base}^{exponent} = {result}")